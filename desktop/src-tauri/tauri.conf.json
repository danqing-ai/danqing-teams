{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DanQing Teams",
  "version": "0.1.0",
  "identifier": "com.danqing.teams",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://localhost:5801/app/",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../../out/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "DanQing Teams",
        "width": 1280,
        "height": 800,
        "titleBarStyle": "Visible",
        "url": "/",
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["bin/danqing-teams-backend"]
  }
}
