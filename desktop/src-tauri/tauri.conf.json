{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DanQing Teams",
  "version": "0.8.1",
  "identifier": "com.danqing.teams",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://localhost:5801/",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../../out/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "DanQing Teams",
        "width": 1280,
        "height": 800,
        "titleBarStyle": "Visible",
        "url": "/",
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["bin/danqing-teams-backend"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3NjFEOUQ3RUQzQkNEOUUKUldTZXpUdnQxOWxocHdya3Y3OVhXTzRESUV3WVc3enZwcUsvTkNQZTRJaUppNmNkdjJrYTMvbksK",
      "endpoints": [
        "https://releases.danqing.ai/danqing-teams/latest.json",
        "https://github.com/danqing-ai/DanQing-Teams/releases/latest/download/latest.json"
      ]
    }
  }
}
