{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DanQing Teams",
  "version": "0.1.0",
  "identifier": "com.danqing.teams",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "DanQing Teams",
        "width": 1280,
        "height": 800,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8080 http://127.0.0.1:8080"
    }
  }
}
